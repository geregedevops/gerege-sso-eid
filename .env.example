# ============================================
# Gerege SSO Platform — Environment Variables
# Copy to .env and fill in production values
# ============================================

# --- Postgres ---
POSTGRES_USER=sso
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gerege_sso_db

# --- Database URL (used by multiple services) ---
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- SSO Server ---
SSO_ISSUER=https://sso.gerege.mn
SSO_PRIVATE_KEY_PATH=/etc/gerege/sso/ec-private.pem
EID_BASE_URL=https://e-id.mn

# --- DAN Gateway (API) ---
DAN_CLIENT_ID=
DAN_CLIENT_SECRET=
DAN_SCOPE=
DAN_CALLBACK_URI=https://dan.gerege.mn/authorized
DAN_TOKEN_URL=https://sso.gov.mn/oauth2/token
DAN_SERVICE_URL=https://sso.gov.mn/oauth2/api/v1/service
DAN_ADMIN_KEY=CHANGE_ME_ADMIN_KEY
DAN_STATE_SECRET=CHANGE_ME_RANDOM_SECRET

# --- DAN Web Dashboard ---
DAN_WEB_SSO_CLIENT=
DAN_WEB_SSO_SECRET=
DAN_WEB_AUTH_SECRET=CHANGE_ME_DAN_WEB_NEXTAUTH_SECRET

# --- API Server ---
SSO_JWKS_URI=https://sso.gerege.mn/.well-known/jwks.json
EID_API_URL=https://api.e-id.mn

# --- Developer Portal ---
DEV_NEXTAUTH_SECRET=CHANGE_ME_DEV_NEXTAUTH_SECRET
DEV_EID_CLIENT_ID=gerege-developer-portal
DEV_EID_CLIENT_SECRET=CHANGE_ME

# --- Test Sandbox ---
TEST_NEXTAUTH_SECRET=CHANGE_ME_TEST_NEXTAUTH_SECRET
TEST_EID_CLIENT_ID=
TEST_EID_CLIENT_SECRET=

# --- d-business.mn ---
DBIZ_NEXTAUTH_SECRET=CHANGE_ME_DBIZ_NEXTAUTH_SECRET
DBIZ_GEREGE_SSO_CLIENT=
DBIZ_GEREGE_SSO_SECRET=

# --- G-Sign ---
ESIGN_TOKEN=
MSSP_URL=https://66.181.165.212:9061/rest/service
